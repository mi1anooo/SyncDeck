<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SyncDeck.ViewModels"
        xmlns:ctrl="using:SyncDeck.Views.Controls"
        xmlns:panels="using:SyncDeck.Views.Panels"
        x:Class="SyncDeck.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="SyncDeck"
        Icon="/Assets/Icons/SyncDeck.ico"
        Width="820" Height="460"
        MinWidth="380" MinHeight="480"
        MaxWidth="1100" MaxHeight="700"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="None"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome">

  <Window.Styles>
    <Style Selector="Button.chrome">
      <Setter Property="Background"      Value="#12FFFFFF" />
      <Setter Property="BorderBrush"     Value="#22FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding"         Value="0" />
      <Setter Property="Cursor"          Value="Hand" />
    </Style>
    <Style Selector="Button.chrome:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#24FFFFFF" />
    </Style>
    <Style Selector="Button.turntablePrimary">
      <Setter Property="Background"      Value="#202020" />
      <Setter Property="BorderBrush"     Value="#38FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding"         Value="0" />
      <Setter Property="Cursor"          Value="Hand" />
    </Style>
    <Style Selector="Button.turntablePrimary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2B2B2B" />
    </Style>
    <Style Selector="Button.turntablePrimary:pressed /template/ ContentPresenter">
      <Setter Property="Background" Value="#141414" />
    </Style>
    <Style Selector="Button.turntableSecondary">
      <Setter Property="Background"      Value="#0E0E0E" />
      <Setter Property="BorderBrush"     Value="#24FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding"         Value="0" />
      <Setter Property="Cursor"          Value="Hand" />
    </Style>
    <Style Selector="Button.turntableSecondary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1B1B1B" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background"  Value="#151515" />
      <Setter Property="Foreground"  Value="#E2E2DC" />
      <Setter Property="BorderBrush" Value="#28FFFFFF" />
    </Style>
  </Window.Styles>

  <Panel>

    <!--
      NO Margin. NO BorderBrush. NO DropShadowEffect.
      CornerRadius="34" + ClipToBounds="True" is the ONLY shaping.
      The window background is Transparent so the OS desktop shows through
      outside the rounded corners.
    -->
    <Border CornerRadius="34"
            ClipToBounds="True"
            Background="#101010"
            BorderThickness="0">

      <Grid RowDefinitions="48,*">

        <!-- Title bar -->
        <ctrl:TitleBarControl Grid.Row="0" x:Name="TitleBar" />

        <!-- ── Landscape layout ──────────────────────────────────────────── -->
        <Grid Grid.Row="1"
              x:Name="LandscapeLayout"
              ColumnDefinitions="2.35*,*"
              Margin="10,0,18,18">

          <!-- Turntable left column -->
          <ctrl:TurntableControl Grid.Column="0"
                                 IsPlaying="{Binding IsPlaying}"
                                 TrackChanging="{Binding TrackChanging}"
                                 AlbumArtData="{Binding AlbumArtData}"
                                 TrackTitle="{Binding TrackTitle}"
                                 Position="{Binding Position}"
                                 Duration="{Binding Duration}"
                                 PlaybackRpm="{Binding Settings.PlaybackRpm}"
                                 Margin="0,-8,0,0" />

          <!-- Right panel -->
          <Grid Grid.Column="1" RowDefinitions="*,Auto" Margin="2,20,6,8">
            <ctrl:TrackMetadataView Grid.Row="0"
                                    TrackTitle="{Binding TrackTitle}"
                                    Artist="{Binding Artist}"
                                    AlbumName="{Binding AlbumName}"
                                    AlbumArtData="{Binding AlbumArtData}"
                                    ElapsedText="{Binding ElapsedText}"
                                    DurationText="{Binding DurationText}" />
            <ctrl:MinimalPlaybackControls Grid.Row="1"
                                          x:Name="Transport"
                                          IsPlaying="{Binding IsPlaying}"
                                          Position="{Binding Position}"
                                          Duration="{Binding Duration}"
                                          ElapsedText="{Binding ElapsedText}"
                                          DurationText="{Binding DurationText}"
                                          PlayPauseCommand="{Binding PlayPauseCommand}"
                                          NextCommand="{Binding NextCommand}"
                                          PreviousCommand="{Binding PreviousCommand}"
                                          Margin="0,0,0,2" />
          </Grid>
        </Grid>

        <!-- ── Compact layout ────────────────────────────────────────────── -->
        <Grid Grid.Row="1"
              x:Name="CompactLayout"
              RowDefinitions="*,Auto,Auto"
              Margin="10,0,10,14"
              IsVisible="False">

          <ctrl:TurntableControl Grid.Row="0"
                                 IsPlaying="{Binding IsPlaying}"
                                 TrackChanging="{Binding TrackChanging}"
                                 AlbumArtData="{Binding AlbumArtData}"
                                 TrackTitle="{Binding TrackTitle}"
                                 Position="{Binding Position}"
                                 Duration="{Binding Duration}"
                                 PlaybackRpm="{Binding Settings.PlaybackRpm}" />

          <ctrl:TrackMetadataView Grid.Row="1"
                                  TrackTitle="{Binding TrackTitle}"
                                  Artist="{Binding Artist}"
                                  AlbumName="{Binding AlbumName}"
                                  AlbumArtData="{Binding AlbumArtData}"
                                  ElapsedText="{Binding ElapsedText}"
                                  DurationText="{Binding DurationText}"
                                  Margin="0,8,0,0" />

          <ctrl:MinimalPlaybackControls Grid.Row="2"
                                        IsPlaying="{Binding IsPlaying}"
                                        Position="{Binding Position}"
                                        Duration="{Binding Duration}"
                                        ElapsedText="{Binding ElapsedText}"
                                        DurationText="{Binding DurationText}"
                                        PlayPauseCommand="{Binding PlayPauseCommand}"
                                        NextCommand="{Binding NextCommand}"
                                        PreviousCommand="{Binding PreviousCommand}"
                                        Margin="0,8,0,0" />
        </Grid>

      </Grid>
    </Border>

    <!-- Settings overlay -->
    <panels:SettingsPanel
        DataContext="{Binding Settings}"
        IsVisible="{Binding $parent[Window].DataContext.IsSettingsOpen}"
        HorizontalAlignment="Right"
        VerticalAlignment="Top"
        Width="292"
        Margin="0,58,26,0"
        ZIndex="100" />

    <!-- Status message -->
    <TextBlock Text="{Binding StatusMessage}"
               Foreground="#A8FFFFFF"
               FontSize="10"
               TextAlignment="Center"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Bottom"
               Margin="24,0,24,26"
               IsVisible="{Binding StatusMessage,
                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

  </Panel>
</Window>
