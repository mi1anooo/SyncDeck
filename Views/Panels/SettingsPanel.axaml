<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SyncDeck.ViewModels"
             x:Class="SyncDeck.Views.Panels.SettingsPanel"
             x:DataType="vm:SettingsViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize"       Value="9" />
      <Setter Property="LetterSpacing" Value="1.2" />
      <Setter Property="FontWeight"    Value="Bold" />
      <Setter Property="Foreground"    Value="{DynamicResource ThemeTextSecondary}" />
      <Setter Property="Margin"        Value="0,8,0,2" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background"    Value="{DynamicResource ThemeButtonFill}" />
      <Setter Property="BorderBrush"   Value="{DynamicResource ThemeButtonBorder}" />
      <Setter Property="Foreground"    Value="{DynamicResource ThemeTextPrimary}" />
      <Setter Property="FontSize"      Value="11" />
      <Setter Property="Height"        Value="28" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.action">
      <Setter Property="Background"    Value="{DynamicResource ThemeButtonFill}" />
      <Setter Property="BorderBrush"   Value="{DynamicResource ThemeButtonBorder}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground"    Value="{DynamicResource ThemeAccentPrimary}" />
      <Setter Property="FontSize"      Value="10" />
      <Setter Property="FontWeight"    Value="SemiBold" />
      <Setter Property="Height"        Value="28" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Cursor"        Value="Hand" />
    </Style>
    <Style Selector="ToggleSwitch">
      <Setter Property="OffContent" Value="" />
      <Setter Property="OnContent"  Value="" />
      <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimary}" />
    </Style>
  </UserControl.Styles>

  <!-- Panel frame -->
  <Border Background="{DynamicResource ThemeSurfacePrimary}"
          BorderBrush="{DynamicResource ThemeFrameBorder}"
          BorderThickness="1"
          CornerRadius="{DynamicResource ThemeInnerCorner}"
          Padding="14,10"
          Margin="6,0">

    <Border.Effect>
      <DropShadowEffect BlurRadius="12" OffsetX="-4" OffsetY="4" Opacity="0.5"
                        Color="#1A1A2E" />
    </Border.Effect>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Spacing="2">

        <!-- Header -->
        <TextBlock Text="SETTINGS"
                   FontSize="10"
                   LetterSpacing="3"
                   FontWeight="Bold"
                   Foreground="{DynamicResource ThemeAccentPrimary}"
                   Margin="0,0,0,6" />

        <Separator Background="{DynamicResource ThemeFrameBorder}" Height="1" Margin="0,2,0,4" />

        <!-- Theme selector -->
        <TextBlock Classes="label" Text="THEME" />
        <ComboBox ItemsSource="{Binding Themes}"
                  SelectedItem="{Binding SelectedTheme}">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding DisplayName}" FontSize="11" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <Button Classes="action"
                Content="RESET THEME"
                Command="{Binding ResetThemeCommand}"
                Margin="0,4,0,0" />

        <Separator Background="{DynamicResource ThemeFrameBorder}" Height="1" Margin="0,8,0,4" />

        <!-- Source selector -->
        <TextBlock Classes="label" Text="MUSIC SOURCE" />
        <ComboBox ItemsSource="{Binding Sources}"
                  SelectedItem="{Binding SelectedSource}" />

        <!-- Spotify -->
        <Button Classes="action"
                Content="{Binding SpotifyStatusText}"
                Command="{Binding SpotifyLoginCommand}"
                Margin="0,6,0,0" />

        <!-- Apple Music -->
        <Button Classes="action"
                Content="{Binding AppleStatusText}"
                Command="{Binding AppleMusicConnectCommand}"
                Margin="0,4,0,0" />

        <Separator Background="{DynamicResource ThemeFrameBorder}" Height="1" Margin="0,8,0,4" />

        <!-- Playlist -->
        <TextBlock Classes="label" Text="PLAYLIST" />
        <ComboBox ItemsSource="{Binding Playlists}"
                  SelectedItem="{Binding SelectedPlaylist}"
                  DisplayMemberBinding="{Binding Name}" />

        <Button Classes="action"
                Content="REFRESH PLAYLISTS"
                Command="{Binding RefreshPlaylistsCommand}"
                Margin="0,4,0,0" />

        <Separator Background="{DynamicResource ThemeFrameBorder}" Height="1" Margin="0,8,0,4" />

        <!-- Toggles -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Shuffle"
                     Foreground="{DynamicResource ThemeTextPrimary}"
                     VerticalAlignment="Center" FontSize="11" />
          <ToggleSwitch Grid.Column="1" IsChecked="{Binding Shuffle}" />
        </Grid>

        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Always on Top"
                     Foreground="{DynamicResource ThemeTextPrimary}"
                     VerticalAlignment="Center" FontSize="11" />
          <ToggleSwitch Grid.Column="1" IsChecked="{Binding AlwaysOnTop}" />
        </Grid>

        <Grid ColumnDefinitions="*,Auto" Margin="0,2">
          <TextBlock Grid.Column="0" Text="Transparency"
                     Foreground="{DynamicResource ThemeTextPrimary}"
                     VerticalAlignment="Center" FontSize="11" />
          <ToggleSwitch Grid.Column="1" IsChecked="{Binding Transparent}" />
        </Grid>

        <Separator Background="{DynamicResource ThemeFrameBorder}" Height="1" Margin="0,8,0,4" />

        <!-- Version footer -->
        <TextBlock Text="SyncDeck v1.0.0"
                   FontSize="8"
                   Foreground="{DynamicResource ThemeTextSecondary}"
                   TextAlignment="Center"
                   Margin="0,4,0,2" />

      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
