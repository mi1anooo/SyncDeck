<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SyncDeck.ViewModels"
             x:Class="SyncDeck.Views.Panels.SettingsPanel"
             x:DataType="vm:SettingsViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="8" />
      <Setter Property="LetterSpacing" Value="2.2" />
      <Setter Property="Foreground" Value="#7FFFFFFF" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,7,0,3" />
    </Style>
    <Style Selector="Button.action">
      <Setter Property="Background" Value="#14FFFFFF" />
      <Setter Property="Foreground" Value="#E5E5DF" />
      <Setter Property="BorderBrush" Value="#26FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.action:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#22FFFFFF" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#151515" />
      <Setter Property="Foreground" Value="#E5E5DF" />
      <Setter Property="BorderBrush" Value="#22FFFFFF" />
      <Setter Property="FontSize" Value="11" />
    </Style>
  </UserControl.Styles>

  <Border CornerRadius="18"
          Background="#F00B0B0B"
          BorderBrush="#28FFFFFF"
          BorderThickness="1"
          Padding="14">
    <Border.Effect>
      <DropShadowEffect BlurRadius="18" Color="#AA000000" OffsetX="0" OffsetY="10" Opacity="0.75" />
    </Border.Effect>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="340">
      <StackPanel Spacing="4">

        <TextBlock Text="SETTINGS"
                   FontSize="9"
                   LetterSpacing="3.1"
                   FontWeight="SemiBold"
                   Foreground="#D8D8D2"
                   Margin="0,0,0,8" />

        <TextBlock Classes="label" Text="MUSIC SOURCE" />
        <ComboBox ItemsSource="{Binding Sources}"
                  SelectedItem="{Binding SelectedSource}" />

        <Button Classes="action"
                Content="{Binding SpotifyStatusText}"
                Command="{Binding SpotifyLoginCommand}"
                Margin="0,7,0,0" />

        <Button Classes="action"
                Content="{Binding AppleStatusText}"
                Command="{Binding AppleMusicConnectCommand}"
                Margin="0,4,0,0" />

        <Border Height="1" Background="#18FFFFFF" Margin="0,10,0,2" />

        <TextBlock Classes="label" Text="THEME" />
        <ComboBox ItemsSource="{Binding Themes}"
                  SelectedItem="{Binding SelectedTheme}">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding DisplayName}" FontSize="11" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Classes="label" Text="PLAYBACK SPEED" />
        <Grid ColumnDefinitions="*,Auto">
          <ComboBox Grid.Column="0"
                    ItemsSource="{Binding PlaybackSpeeds}"
                    SelectedItem="{Binding PlaybackRpm}" />
          <TextBlock Grid.Column="1"
                     Text="RPM"
                     FontSize="10"
                     LetterSpacing="1.4"
                     Foreground="#78FFFFFF"
                     VerticalAlignment="Center"
                     Margin="8,0,0,0" />
        </Grid>

        <Border Height="1" Background="#18FFFFFF" Margin="0,10,0,2" />

        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
          <TextBlock Grid.Column="0" Text="Shuffle"
                     Foreground="#CFCFC9"
                     VerticalAlignment="Center" FontSize="11" />
          <ToggleSwitch Grid.Column="1" IsChecked="{Binding Shuffle}" />
        </Grid>

        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
          <TextBlock Grid.Column="0" Text="Always on Top"
                     Foreground="#CFCFC9"
                     VerticalAlignment="Center" FontSize="11" />
          <ToggleSwitch Grid.Column="1" IsChecked="{Binding AlwaysOnTop}" />
        </Grid>

        <Grid ColumnDefinitions="*,Auto" Margin="0,4">
          <TextBlock Grid.Column="0" Text="Transparency"
                     Foreground="#CFCFC9"
                     VerticalAlignment="Center" FontSize="11" />
          <ToggleSwitch Grid.Column="1" IsChecked="{Binding Transparent}" />
        </Grid>

        <Button Classes="action"
                Content="REFRESH PLAYLISTS"
                Command="{Binding RefreshPlaylistsCommand}"
                Margin="0,8,0,0" />

        <TextBlock Text="SyncDeck v1.0.0"
                   FontSize="8"
                   Foreground="#60FFFFFF"
                   TextAlignment="Center"
                   Margin="0,10,0,0" />

      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
