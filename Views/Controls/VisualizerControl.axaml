<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SyncDeck.Views.Controls.VisualizerControl"
             MinHeight="160">

  <Border Background="{DynamicResource ThemeSurfaceSecondary}"
          BorderBrush="{DynamicResource ThemeFrameBorder}"
          BorderThickness="1"
          CornerRadius="{DynamicResource ThemeInnerCorner}"
          ClipToBounds="True">

    <!-- Custom-drawn visualizer via Canvas — animated in code-behind -->
    <Canvas x:Name="VisCanvas"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />

  </Border>
</UserControl>
