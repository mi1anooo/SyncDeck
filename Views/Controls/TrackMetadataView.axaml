<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SyncDeck.Views.Controls.TrackMetadataView">

  <Grid RowDefinitions="Auto,*,Auto" Margin="2,0,0,0">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
      <Border Width="42" Height="42"
              CornerRadius="21"
              BorderBrush="#55FFFFFF"
              BorderThickness="1"
              Background="#1A1A1A"
              ClipToBounds="True">
        <Canvas x:Name="AvatarCanvas" Width="42" Height="42" />
      </Border>

      <StackPanel VerticalAlignment="Center" Spacing="2">
        <TextBlock Text="NOW PLAYING"
                   FontSize="8"
                   LetterSpacing="2.6"
                   Foreground="#78FFFFFF"
                   FontWeight="SemiBold" />
        <Border Width="62" Height="1" Background="#2BFFFFFF" HorizontalAlignment="Left" />
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="7" Margin="0,0,8,0">
      <TextBlock x:Name="TitleLabel"
                 FontSize="20"
                 FontWeight="SemiBold"
                 LineHeight="22"
                 Foreground="#ECECEC"
                 TextWrapping="Wrap"
                 MaxLines="2" />
      <TextBlock x:Name="ArtistLabel"
                 FontSize="12"
                 Foreground="#A7A7A3"
                 TextTrimming="CharacterEllipsis" />
      <TextBlock x:Name="AlbumLabel"
                 FontSize="10"
                 LetterSpacing="1.2"
                 Foreground="#70FFFFFF"
                 TextTrimming="CharacterEllipsis" />
    </StackPanel>

    <Grid Grid.Row="2" RowDefinitions="Auto,Auto" Margin="0,0,12,4">
      <Grid ColumnDefinitions="Auto,*,Auto" Height="18">
        <TextBlock Grid.Column="0"
                   x:Name="ElapsedLabel"
                   FontSize="10"
                   Foreground="#DADAD4"
                   FontFamily="Consolas, Courier New" />
        <Border Grid.Column="1"
                Height="1"
                Background="#25FFFFFF"
                Margin="8,8,8,0"
                VerticalAlignment="Top" />
        <TextBlock Grid.Column="2"
                   x:Name="DurationLabel"
                   FontSize="10"
                   Foreground="#74FFFFFF"
                   FontFamily="Consolas, Courier New" />
      </Grid>
      <TextBlock Grid.Row="1"
                 Text="LOCAL DECK OUTPUT"
                 FontSize="7"
                 LetterSpacing="2.4"
                 Foreground="#45FFFFFF"
                 HorizontalAlignment="Left"
                 Margin="0,5,0,0" />
    </Grid>

  </Grid>
</UserControl>
