<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SyncDeck.Views.Controls.TitleBarControl"
             Height="44">

  <Grid ColumnDefinitions="Auto,*,Auto" Background="Transparent">

    <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="22,0,0,0"
                Spacing="9">
      <Canvas Width="18" Height="18" VerticalAlignment="Center">
        <Ellipse Width="18" Height="18"
                 Stroke="#B6FFFFFF"
                 StrokeThickness="1.5"
                 Fill="Transparent" />
        <Path Data="M 10.8 4.2 C 8.5 3.1 5.8 4.5 5.8 7.2 C 5.8 9.8 8.3 10.7 10.3 11.3 C 11.1 11.6 11.1 13.1 9.5 13.8 C 7.4 14.7 5.3 13.4 4.6 11.8"
              Stroke="#D8D8D2"
              StrokeThickness="1.2"
              StrokeLineCap="Round"
              Fill="Transparent" />
      </Canvas>
      <TextBlock Text="SYNCDECK"
                 FontSize="11"
                 FontWeight="SemiBold"
                 LetterSpacing="3.1"
                 Foreground="#D8D8D2"
                 VerticalAlignment="Center" />
    </StackPanel>

    <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0,0,18,0"
                Spacing="6">

      <Button x:Name="SettingsBtn"
              Classes="chrome"
              Width="28" Height="28"
              CornerRadius="14"
              ToolTip.Tip="Settings">
        <TextBlock Text="⋯"
                   FontSize="18"
                   Foreground="#B6FFFFFF"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="0,-5,0,0" />
      </Button>

      <Button x:Name="MinimizeBtn"
              Classes="chrome"
              Width="22" Height="22"
              CornerRadius="11"
              ToolTip.Tip="Minimize">
        <Canvas Width="8" Height="8">
          <Line StartPoint="1,5" EndPoint="7,5" Stroke="#8DFFFFFF" StrokeThickness="1.3" />
        </Canvas>
      </Button>

      <Button x:Name="MaximizeBtn"
              Classes="chrome"
              Width="22" Height="22"
              CornerRadius="11"
              ToolTip.Tip="Maximize / Restore">
        <Canvas Width="8" Height="8">
          <Rectangle Canvas.Left="1.5" Canvas.Top="1.5" Width="5" Height="5"
                     Stroke="#8DFFFFFF" StrokeThickness="1" Fill="Transparent" />
        </Canvas>
      </Button>

      <Button x:Name="CloseBtn"
              Classes="chrome"
              Width="22" Height="22"
              CornerRadius="11"
              ToolTip.Tip="Close">
        <Canvas Width="8" Height="8">
          <Line StartPoint="1.5,1.5" EndPoint="6.5,6.5" Stroke="#B6FFFFFF" StrokeThickness="1.15" />
          <Line StartPoint="6.5,1.5" EndPoint="1.5,6.5" Stroke="#B6FFFFFF" StrokeThickness="1.15" />
        </Canvas>
      </Button>

    </StackPanel>
  </Grid>
</UserControl>
