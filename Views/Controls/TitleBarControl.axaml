<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SyncDeck.Views.Controls.TitleBarControl"
             Height="36">

  <Border Background="{DynamicResource ThemeSurfacePrimary}"
          BorderBrush="{DynamicResource ThemeFrameBorder}"
          BorderThickness="0,0,0,1">

    <Grid ColumnDefinitions="Auto,*,Auto">

      <!-- App name -->
      <StackPanel Grid.Column="0"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="10,0,0,0"
                  Spacing="6">

        <!-- Logo mark: small accent diamond -->
        <Canvas Width="10" Height="10" VerticalAlignment="Center">
          <Polygon Points="5,0 10,5 5,10 0,5"
                   Fill="{DynamicResource ThemeAccentPrimary}" />
        </Canvas>

        <TextBlock Text="SYNCDECK"
                   FontSize="11"
                   FontWeight="Bold"
                   LetterSpacing="2"
                   Foreground="{DynamicResource ThemeTextPrimary}"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Window chrome buttons -->
      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  VerticalAlignment="Center"
                  Margin="0,0,6,0"
                  Spacing="4">

        <!-- Settings -->
        <Button x:Name="SettingsBtn"
                Classes="chrome"
                Width="22" Height="22"
                CornerRadius="3"
                ToolTip.Tip="Settings">
          <Canvas Width="12" Height="12">
            <!-- Gear icon (simplified) -->
            <Ellipse Canvas.Left="3" Canvas.Top="3" Width="6" Height="6"
                     Stroke="{DynamicResource ThemeTextSecondary}" StrokeThickness="1.5"
                     Fill="Transparent" />
            <Line StartPoint="6,0" EndPoint="6,3"
                  Stroke="{DynamicResource ThemeTextSecondary}" StrokeThickness="1.5" />
            <Line StartPoint="6,9" EndPoint="6,12"
                  Stroke="{DynamicResource ThemeTextSecondary}" StrokeThickness="1.5" />
            <Line StartPoint="0,6" EndPoint="3,6"
                  Stroke="{DynamicResource ThemeTextSecondary}" StrokeThickness="1.5" />
            <Line StartPoint="9,6" EndPoint="12,6"
                  Stroke="{DynamicResource ThemeTextSecondary}" StrokeThickness="1.5" />
          </Canvas>
        </Button>

        <!-- Minimize — underscore bar -->
        <Button x:Name="MinimizeBtn"
                Classes="chrome"
                Width="22" Height="22"
                CornerRadius="3"
                ToolTip.Tip="Minimize">
          <Canvas Width="10" Height="2">
            <Line StartPoint="0,1" EndPoint="10,1"
                  Stroke="{DynamicResource ThemeTextSecondary}" StrokeThickness="1.5" />
          </Canvas>
        </Button>

        <!-- Maximize — outer square with inner accent corner -->
        <Button x:Name="MaximizeBtn"
                Classes="chrome"
                Width="22" Height="22"
                CornerRadius="3"
                ToolTip.Tip="Maximize / Restore">
          <Canvas Width="10" Height="10">
            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="10" Height="10"
                       Stroke="{DynamicResource ThemeTextSecondary}" StrokeThickness="1.5"
                       Fill="Transparent" />
            <Line StartPoint="0,3" EndPoint="10,3"
                  Stroke="{DynamicResource ThemeAccentPrimary}" StrokeThickness="1" />
          </Canvas>
        </Button>

        <!-- Close — X -->
        <Button x:Name="CloseBtn"
                Classes="chrome"
                Width="22" Height="22"
                CornerRadius="3"
                ToolTip.Tip="Close">
          <Canvas Width="10" Height="10">
            <Line StartPoint="0,0" EndPoint="10,10"
                  Stroke="{DynamicResource ThemeAccentPrimary}" StrokeThickness="1.5" />
            <Line StartPoint="10,0" EndPoint="0,10"
                  Stroke="{DynamicResource ThemeAccentPrimary}" StrokeThickness="1.5" />
          </Canvas>
        </Button>

      </StackPanel>
    </Grid>
  </Border>
</UserControl>
