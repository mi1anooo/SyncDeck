<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SyncDeck.Views.Controls.TitleBarControl"
             Height="48">

  <Grid ColumnDefinitions="Auto,*,Auto" Background="Transparent">

    <!-- ── Logo + wordmark ──────────────────────────────────────────────────── -->
    <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="20,0,0,0"
                Spacing="10">

      <!-- Logo: stacked diamond / disc mark -->
      <Canvas Width="20" Height="20" VerticalAlignment="Center">
        <!-- Outer diamond -->
        <Polygon Points="10,0 20,10 10,20 0,10"
                 Fill="Transparent"
                 Stroke="#C8C8C2"
                 StrokeThickness="1.2" />
        <!-- Inner filled diamond -->
        <Polygon Points="10,4.5 15.5,10 10,15.5 4.5,10"
                 Fill="#C8C8C2"
                 Stroke="Transparent" />
        <!-- Centre dot -->
        <Ellipse Canvas.Left="8.5" Canvas.Top="8.5"
                 Width="3" Height="3"
                 Fill="#0D0D0D" />
      </Canvas>

      <TextBlock Text="SYNCDECK"
                 FontSize="11"
                 FontWeight="SemiBold"
                 LetterSpacing="3.5"
                 Foreground="#C8C8C2"
                 VerticalAlignment="Center" />
    </StackPanel>

    <!-- ── Window chrome — macOS-inspired dots ───────────────────────────────── -->
    <StackPanel Grid.Column="2"
                Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0,0,20,0"
                Spacing="8">

      <!-- Settings -->
      <Button x:Name="SettingsBtn"
              Width="26" Height="26"
              CornerRadius="13"
              Background="#1E1E1E"
              BorderBrush="#2E2E2E"
              BorderThickness="1"
              Padding="0"
              Cursor="Hand"
              ToolTip.Tip="Settings">
        <!-- Three dots arranged vertically -->
        <Canvas Width="14" Height="14">
          <Ellipse Canvas.Left="5.5" Canvas.Top="2"   Width="3" Height="3" Fill="#888880" />
          <Ellipse Canvas.Left="5.5" Canvas.Top="5.5" Width="3" Height="3" Fill="#888880" />
          <Ellipse Canvas.Left="5.5" Canvas.Top="9"   Width="3" Height="3" Fill="#888880" />
        </Canvas>
      </Button>

      <!-- Separator -->
      <Rectangle Width="1" Height="14"
                 Fill="#282828"
                 VerticalAlignment="Center" />

      <!-- Minimize — yellow dot -->
      <Button x:Name="MinimizeBtn"
              Width="14" Height="14"
              CornerRadius="7"
              Background="#F5A623"
              BorderThickness="0"
              Padding="0"
              Cursor="Hand"
              ToolTip.Tip="Minimize">
        <Canvas />
      </Button>

      <!-- Maximize — green dot -->
      <Button x:Name="MaximizeBtn"
              Width="14" Height="14"
              CornerRadius="7"
              Background="#5BB974"
              BorderThickness="0"
              Padding="0"
              Cursor="Hand"
              ToolTip.Tip="Maximize / Restore">
        <Canvas />
      </Button>

      <!-- Close — red dot -->
      <Button x:Name="CloseBtn"
              Width="14" Height="14"
              CornerRadius="7"
              Background="#E74C3C"
              BorderThickness="0"
              Padding="0"
              Cursor="Hand"
              ToolTip.Tip="Close">
        <Canvas />
      </Button>

    </StackPanel>
  </Grid>
</UserControl>
